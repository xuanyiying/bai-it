{
  "expo": {
    "name": "BaiitMobile",
    "slug": "BaiitMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2196F3"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.baiit.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "允许 BaiitMobile 使用 Face ID 进行身份验证"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2196F3"
      },
      "package": "com.baiit.mobile"
    },
    "plugins": [
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "33fa7e66-04c9-4f0b-921f-666b536420a7"
      }
    },
    "owner": "altay-net"
  }
}
